# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
# production build cache (separate dir so builds never touch the dev .next cache)
/.next-build/
/out/
next-env.d.ts

# production
/build

# local data — NEVER commit (master profile, tokens, browser profile, backups)
/data/
*.local

# secrets
.env
.env*.local
.env.production
# Gmail OAuth tokens (Phase 6) — crown-jewel session credential, never commit.
# Keep out of iCloud/Time-Machine sync and behind FileVault (plan §D).
/.secrets/
# Encrypted profile snapshots (Phase 11) — the master profile, never commit.
/.backups/

# Tauri desktop build output (Phase 12)
/src-tauri/target/
/src-tauri/gen/

# launchd logs
/.logs/

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo

# os / editor
.idea/
.vscode/*
!.vscode/extensions.json
