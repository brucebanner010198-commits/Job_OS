# ─── OpenRouter (AI gateway) ─────────────────────────────────────────────
# Prefer the in-app Integrations portal (/integrations) — keys are stored in
# .secrets/keys.json. These env vars are a fallback for CI/headless setups.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
APP_URL=http://localhost:3000

# Model routing — cheap by default, strong only where quality is the product.
# These are OpenRouter model slugs; override to taste.
MODEL_CHEAP=google/gemini-2.5-flash-lite
MODEL_STANDARD=google/gemini-2.5-flash
MODEL_STRONG=anthropic/claude-sonnet-4.6
EMBEDDING_MODEL=openai/text-embedding-3-small

# Enforce zero-data-retention routing on every OpenRouter call (1 = on).
OPENROUTER_ENFORCE_ZDR=1

# Job relevance scoring: "embedding" (default, uses pgvector when key set) or
# "lexical" (offline/deterministic token overlap only).
SCORING_MODE=embedding

# ─── Database (local Postgres + pgvector via docker compose) ──────────────
DATABASE_URL=postgresql://jobos:jobos@localhost:5432/jobos?schema=public

# ─── Access control (non-localhost deployments) ───────────────────────────
# When set, API routes (/api/backup/*, /api/gmail/* except OAuth) require
# Authorization: Bearer <token> or ?token=... on any host that is NOT localhost.
# Leave blank for local-only dev (no gate).
JOB_OS_ACCESS_TOKEN=

# ─── Single-user identity (local-first; multi-user is additive later) ─────
# A stable id/email for the one local user. Created on first run if absent.
PRIMARY_USER_EMAIL=you@example.com

# ─── Job discovery (Phase 3) ──────────────────────────────────────────────
# JSearch is the paid data spine (RapidAPI). Leave blank to run on free
# sources + built-in fixtures only — the app stays fully usable without it.
JSEARCH_API_KEY=
# Comma-separated default search, used by the discovery run.
JOBS_DEFAULT_QUERY=software engineer
# Set to 0 to disable built-in fixture jobs (offline/dev previews).
JOBS_USE_FIXTURES=1
# Optional Crunchbase enrichment — REMOVED from default brief pipeline.
# Leave blank; web-research + EDGAR + official sources are used instead.
CRUNCHBASE_API_KEY=
# Free-source toggle (Remotive + RemoteOK + Arbeitnow + Jobicy). 1 = on.
JOBS_FREE_SOURCES=1

# ─── Web research briefs (Phase 2) ────────────────────────────────────────
SEC_EDGAR_USER_AGENT=
SEARXNG_URL=

# ─── Knowledge Notebook RAG (Phase 3) ─────────────────────────────────────
KNOWLEDGE_NOTEBOOK_ENABLED=1

# ─── Gmail (Phase 6 — Track) ──────────────────────────────────────────────
# The app reads Gmail (read-only) via the official API to PROPOSE status
# changes — it never auto-flips a status and never sends mail. OAuth tokens are
# stored locally in .secrets/ (gitignored), NEVER in the database.
#
# Setup (one-time, ~10 min — see the in-app /track "Connect Gmail" guide):
#   1. console.cloud.google.com -> new project.
#   2. Enable the "Gmail API" (APIs & Services -> Library).
#   3. OAuth consent screen -> External -> add yourself as a user ->
#      PUBLISH to "In production" (avoids the 7-day test-token expiry).
#   4. Credentials -> Create OAuth client ID -> "Web application" ->
#      Authorized redirect URI: http://localhost:3000/api/gmail/callback
#   5. Paste the client id/secret below, run the app, open /track, Connect Gmail.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback
# Kill-switch: set to 0 to force offline fixtures even when connected.
GMAIL_ENABLED=1
# Optional: a refresh token from a one-time consent (headless/CI). Normally you
# connect through the app instead and this stays blank.
GMAIL_REFRESH_TOKEN=

# ─── Warm-path / referrals (Phase 7) ──────────────────────────────────────
# The referral engine finds a path INTO a target company before you apply cold.
# By default it runs on built-in fixtures, and you can always import your
# connections manually. The LIVE source reads your OWN LinkedIn network from your
# local, logged-in browser session — local-only, human-in-the-loop, never
# scraping others at scale, and auto-disabled on any cloud deploy. The real
# local-session reader ships with the packaged desktop app; set this to 1 only
# there. Leaving it blank keeps the engine on deterministic fixtures.
WARM_LINKEDIN_ENABLED=
# Set to 1 in a cloud deployment to force-disable all local browser automation.
JOB_OS_CLOUD=

# ─── Interview prep — live voice (Phase 8) ────────────────────────────────
# Study mode (top-5 Q&A) is ALWAYS free and offline — no key needed. The two
# LIVE voice modes (AI-screen + real-HR) use ElevenLabs conversational AI in the
# browser. Leave these blank to run zero-cost SCRIPTED MOCK sessions instead — the
# full flow (turn-taking → transcript → score) still works, it just isn't live.
#
# The API key is read SERVER-SIDE ONLY to mint a short-lived signed URL; it is
# never sent to the browser. Use TWO DISTINCT agent ids so the robotic screener
# and the warm HR personas never bleed.
#
# Setup (optional): create two ElevenLabs Conversational AI agents, then:
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_AI_SCREEN=
ELEVENLABS_AGENT_REAL_HR=
# Hard kill-switch: set to 1 to force live voice OFF (runs the mock everywhere).
ELEVENLABS_VOICE_DISABLED=
# Cost caps are enforced in code (per-session limit, idle auto-hangup, daily
# kill-switch) — see DEFAULT_VOICE_CAPS in lib/interview/types.ts.
#
# LOWER-COST alternative (Phase 13): Cartesia + Pipecat (~$0.03–0.05/min vs
# ElevenLabs ~$0.08–0.16/min) — the recommended default for heavy practice. Since
# Cartesia is TTS/STT, the conversation loop runs on a small Pipecat bot runner you
# host locally; this app only needs its connect endpoint (the Cartesia key lives on
# the runner, never here). Set VOICE_PROVIDER=cartesia to prefer it.
VOICE_PROVIDER=
PIPECAT_CONNECT_URL=
# Optional bearer token if your Pipecat connect endpoint requires auth.
PIPECAT_CONNECT_TOKEN=
# Hard kill-switch: set to 1 to force the Cartesia path off.
CARTESIA_VOICE_DISABLED=

# ─── Autopilot orchestrator (Phase 6) ─────────────────────────────────────
# Chain discover → brief → prepare → auto-submit AUTONOMOUS only.
AUTOPILOT_ENABLED=1
# Quality gate thresholds — autopilot skips jobs below these scores.
QUALITY_GATE_MIN_JOB_SCORE=0.55
QUALITY_GATE_MIN_SCREENING=65
# Optional: minimum ATS keyword match percent (blank = use code default).
QUALITY_GATE_MIN_KEYWORD_MATCH=
# Cap autonomous auto-submits per day (safety rail).
QUALITY_GATE_MAX_DAILY_AUTO=5
# Quality gate — block low-probability auto-applies (see lib/autopilot/quality-gate.ts).
QUALITY_GATE_MIN_JOB_SCORE=0.55
QUALITY_GATE_MIN_SCREENING=65
QUALITY_GATE_MIN_KEYWORD_MATCH=70
QUALITY_GATE_MAX_DAILY_AUTO=5
# "Local-first can't mean 24/7": the catch-up runner (scripts/run-catchup.ts,
# `npm run catchup`) re-runs only the jobs that are DUE since they last ran —
# idempotently — so a job missed while the laptop slept runs once on wake and
# never double-runs. Schedule it with the macOS launchd agent the /outcomes
# "Automation" panel generates for you (RunAtLoad fires it on wake; StartInterval
# keeps it ticking). No env is required for the default polling setup.
#
# OPTIONAL Gmail push relay — the one always-on cloud piece. With a Gmail `watch`
# Pub/Sub topic, a tiny always-on subscriber can trigger the SAME idempotent sync
# near-instantly (so an interview invite is seen in seconds, not at the next
# wake). Leave blank to stay on polling-on-wake (the default).
GMAIL_PUBSUB_TOPIC=
# Kill-switch: set to 0 to force polling even when a topic is configured.
GMAIL_PUSH_ENABLED=
# Shared secret that secures the push webhook (Phase 14). The webhook at
# /api/gmail/push only runs a sync when the Pub/Sub push presents this token as
# ?token=... — without it set, the relay is OFF and the webhook rejects all calls.
# Register the watch with POST /api/gmail/watch (re-run ~weekly; it expires in 7d).
GMAIL_PUSH_TOKEN=

# ─── Apply driver (Phase 10) ──────────────────────────────────────────────
# The apply engine fills + submits forms through a swappable ApplyDriver. The
# DEFAULT is a deterministic SIMULATED driver (offline, used by the tests and the
# offline preview) — it never touches a real browser. Set APPLY_DRIVER=playwright
# to use the REAL driver, which drives your OWN installed Chrome via a dedicated,
# persistent automation profile (channel:"chrome" — no browser download needed;
# reuses your logins). It is LOCAL-ONLY and auto-disables when JOB_OS_CLOUD=1.
#
# Safety is unchanged: every submit still passes the itemized human review gate,
# concurrency is 1 (no double-submit), and a LIVE detection scan aborts before
# submit if a CAPTCHA/login/Cloudflare wall appears. Use APPLY_DRY_RUN=1 to fill
# the form but never click submit (safe live testing).
#
# One-time: install Google Chrome, then `npx playwright install chromium` is NOT
# required (we use your system Chrome). Just set APPLY_DRIVER=playwright locally.
APPLY_DRIVER=
# Fill but never submit (1 = dry run). Great for first trials.
APPLY_DRY_RUN=
# Run Chrome headless (1) instead of visibly. Default visible so you can watch.
APPLY_HEADLESS=
# Where the dedicated automation Chrome profile lives (the "crown-jewel" session).
# Defaults to .secrets/apply-chrome-profile (gitignored, mode 0700). Keep it out
# of iCloud/Time-Machine and behind FileVault (plan §D).
APPLY_CHROME_PROFILE_DIR=
# Optional path to a master resume PDF for Playwright upload (overrides tailor HTML).
APPLY_RESUME_PDF=

# ─── Profile backups (Phase 11) ───────────────────────────────────────────
# The master profile is encrypted (AES-256-GCM) into versioned snapshots under
# the gitignored /.backups dir. The encryption key is auto-generated to
# .secrets/backup.key (mode 0600) on first backup — no setup needed. Set
# BACKUP_KEY only if you want to supply your own (32 bytes, base64 or hex).
BACKUP_KEY=

# ─── Desktop build + OS keychain (Phase 12) ───────────────────────────────
# When running inside the packaged Tauri desktop app, set JOB_OS_DESKTOP=1 so
# secrets resolve from the macOS Keychain (via the optional `keytar` dependency)
# instead of this .env file. Outside the desktop build it stays on .env — no-op.
# If keytar isn't installed it falls back to .env gracefully (never throws).
JOB_OS_DESKTOP=
# Keychain service namespace (all Job OS secrets live under one service).
KEYCHAIN_SERVICE=com.jobos.app

# ─── Career agent (background polish + target refresh) ─────────────────────
# Optional polling interval and caps for the career-agent catchup job.
CAREER_AGENT_INTERVAL_SEC=
CAREER_AGENT_MAX_TARGETS=
CAREER_AGENT_MAX_POLISH=

# ─── Local secrets directory ──────────────────────────────────────────────
# Portal keys and OAuth tokens live in .secrets/ (gitignored). Exclude this
# directory from iCloud Drive, Dropbox, and Time Machine sync. Enable FileVault
# on macOS for at-rest encryption.
